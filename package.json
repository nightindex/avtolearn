{
  "name": "avtolearn-ai-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite --host 127.0.0.1 --port 5177 --strictPort",
    "download:subjects": "node tools/download-subjects.cjs",
    "download:exam-questions": "node tools/download-exam-questions.cjs",
    "mirror:exam-media": "node tools/mirror-exam-media.cjs",
    "download:road-signs": "node tools/download-road-signs.cjs",
    "download:penalties": "node tools/download-penalties.cjs",
    "db:backup": "node tools/backup-db.cjs",
    "build": "tsc -b && vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^10.0.3",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  },
  "description": "Modern local-first driving education dashboard inspired by Eavtota'lim.",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
